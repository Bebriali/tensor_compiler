digraph CFG_Optimized_Instructions {
    node [shape=none, fontname="Courier New", fontsize=10];
    edge [fontname="Arial", fontsize=9];
    rankdir=TB;

    bb0 [label=<
        <table border="0" cellborder="1" cellspacing="0" cellpadding="4" bgcolor="#e1f5fe">
            <tr><td bgcolor="#b3e5fc"><b>bb0: Entry</b></td></tr>
            <tr><td align="left">res0 = 0</td></tr>
            <tr><td align="left">i0 = 0</td></tr>
            <tr><td align="left">br bb1</td></tr>
        </table>>];

    bb1 [label=<
        <table border="0" cellborder="1" cellspacing="0" cellpadding="4" bgcolor="#fff9c4">
            <tr><td bgcolor="#fff176"><b>bb1: Loop Header</b></td></tr>
            <tr><td align="left">i1 = phi(i0, i_inc)</td></tr>
            <tr><td align="left">res1 = phi(res0, res_inc)</td></tr>
            <tr><td align="left">cmp1 = i1 &lt; n</td></tr>
            <tr><td align="left">br cmp1, bb2, bb5</td></tr>
        </table>>];

    bb2 [label=<
        <table border="0" cellborder="1" cellspacing="0" cellpadding="4" bgcolor="#fff9c4">
            <tr><td bgcolor="#fff176"><b>bb2: Split</b></td></tr>
            <tr><td align="left">bit = i1 &amp; 1</td></tr>
            <tr><td align="left">cmp2 = bit == 0</td></tr>
            <tr><td align="left">br cmp2, bb3, bb4</td></tr>
        </table>>];

    bb3 [label=<
        <table border="0" cellborder="1" cellspacing="0" cellpadding="4" bgcolor="#c8e6c9">
            <tr><td bgcolor="#a5d6a7"><b>bb3: Then (Even)</b></td></tr>
            <tr><td align="left">addr3 = getelementptr a, i1</td></tr>
            <tr><td align="left">val3 = load [addr3]</td></tr>
            <tr><td align="left">term3 = val3 &lt;&lt; 1</td></tr>
            <tr><td align="left">res3 = res1 + term3</td></tr>
            <tr><td align="left">br bb_inc</td></tr>
        </table>>];

    bb4 [label=<
        <table border="0" cellborder="1" cellspacing="0" cellpadding="4" bgcolor="#ffcdd2">
            <tr><td bgcolor="#ef9a9a"><b>bb4: Else (Odd)</b></td></tr>
            <tr><td align="left">addr4 = getelementptr a, i1</td></tr>
            <tr><td align="left">val4 = load [addr4]</td></tr>
            <tr><td align="left">term4 = val4 + 2</td></tr>
            <tr><td align="left">res4 = res1 - term4</td></tr>
            <tr><td align="left">br bb_inc</td></tr>
        </table>>];

    bb_inc [label=<
        <table border="0" cellborder="1" cellspacing="0" cellpadding="4" bgcolor="#e1f5fe">
            <tr><td bgcolor="#b3e5fc"><b>bb_inc: Increment</b></td></tr>
            <tr><td align="left">res_inc = phi(res3, res4)</td></tr>
            <tr><td align="left">i_inc = i1 + 1</td></tr>
            <tr><td align="left">br bb1</td></tr>
        </table>>];

    bb5 [label=<
        <table border="0" cellborder="1" cellspacing="0" cellpadding="4" bgcolor="#cfd8dc">
            <tr><td bgcolor="#b0bec5"><b>bb5: Exit</b></td></tr>
            <tr><td align="left">return res1</td></tr>
        </table>>];

    bb0 -> bb1; bb1 -> bb2; bb1 -> bb5; bb2 -> bb3; bb2 -> bb4; bb3 -> bb_inc; bb4 -> bb_inc; bb_inc -> bb1;
}
